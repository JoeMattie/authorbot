{
  "name": "@authorbot/markdown",
  "version": "0.1.14",
  "description": "Markdown parsing, block-marker extraction, safety scanning, work-item delimiter checks, and normalized text streams for Authorbot chapter files (Phase 0 contract section 3)",
  "keywords": [
    "authorbot",
    "markdown",
    "remark",
    "frontmatter"
  ],
  "license": "MIT",
  "author": "Joe Mattie",
  "homepage": "https://github.com/JoeMattie/authorbot#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JoeMattie/authorbot.git",
    "directory": "packages/markdown"
  },
  "bugs": {
    "url": "https://github.com/JoeMattie/authorbot/issues"
  },
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "!dist/**/*.map"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "node ../../scripts/copy-license.mjs",
    "test": "vitest run --testTimeout=30000",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@types/mdast": "^4.0.0",
    "@types/unist": "^3.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.0",
    "unist-util-visit": "^5.0.0",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
