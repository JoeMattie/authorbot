{
  "name": "@authorbot/rule-engine",
  "version": "0.1.18",
  "description": "Pure declarative rule evaluation for Authorbot governance: vote-tally metric computation and threshold evaluation of the authorbot.instance/v1 rule shape (Phase 3 contract section 3). No user-supplied code is ever evaluated.",
  "keywords": [
    "authorbot",
    "rules",
    "governance"
  ],
  "license": "MIT",
  "author": "Joe Mattie",
  "homepage": "https://github.com/JoeMattie/authorbot#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JoeMattie/authorbot.git",
    "directory": "packages/rule-engine"
  },
  "bugs": {
    "url": "https://github.com/JoeMattie/authorbot/issues"
  },
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "CHANGELOG.md",
    "!dist/**/*.map"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "node ../../scripts/copy-license.mjs",
    "test": "vitest run --testTimeout=30000",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@authorbot/schemas": "workspace:*",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
