{
  "$id": "authorbot.character/v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema": {
      "type": "string",
      "const": "authorbot.character/v1"
    },
    "id": {
      "type": "string",
      "pattern": "^character:[a-z0-9][a-z0-9-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "summary": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "schema",
    "id",
    "name"
  ],
  "additionalProperties": false
}
