{
  "$id": "authorbot.build/v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema": {
      "type": "string",
      "const": "authorbot.build/v1"
    },
    "commit": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^[0-9a-f]{7,64}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "built_at": {
      "type": "string",
      "pattern": "^\\d{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12]\\d|3[01])T(?:[01]\\d|2[0-3]):[0-5]\\d:(?:[0-5]\\d|60)(?:\\.\\d{1,9})?Z$"
    },
    "publisher_version": {
      "type": "string",
      "minLength": 1
    },
    "base_url": {
      "type": "string",
      "minLength": 1
    },
    "chapters": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
          },
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "revision": {
            "type": "integer",
            "minimum": 1,
            "maximum": 9007199254740991
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "proposed",
              "published",
              "archived"
            ]
          }
        },
        "required": [
          "id",
          "slug",
          "revision",
          "title",
          "status"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "schema",
    "commit",
    "built_at",
    "publisher_version",
    "chapters"
  ],
  "additionalProperties": false
}
