{
  "$id": "authorbot.work-item/v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema": {
      "type": "string",
      "const": "authorbot.work-item/v1"
    },
    "id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "type": {
      "type": "string",
      "enum": [
        "revise_range",
        "revise_block",
        "revise_chapter",
        "write_chapter",
        "resolve_conflict",
        "planning"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "ready",
        "leased",
        "submitted",
        "applying",
        "completed",
        "conflict",
        "failed",
        "cancelled"
      ]
    },
    "source_annotation_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "chapter_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "base_revision": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "normal",
        "high"
      ]
    },
    "created_by": {
      "type": "string",
      "pattern": "^(?:github|agent|system):[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "created_at": {
      "type": "string",
      "pattern": "^\\d{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12]\\d|3[01])T(?:[01]\\d|2[0-3]):[0-5]\\d:(?:[0-5]\\d|60)(?:\\.\\d{1,9})?Z$"
    }
  },
  "required": [
    "schema",
    "id",
    "type",
    "status",
    "priority",
    "created_by",
    "created_at"
  ],
  "additionalProperties": false
}
