{
  "$id": "authorbot.annotation/v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "schema": {
          "type": "string",
          "const": "authorbot.annotation/v1"
        },
        "id": {
          "type": "string",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
        },
        "kind": {
          "type": "string",
          "enum": [
            "comment",
            "suggestion"
          ]
        },
        "chapter_id": {
          "type": "string",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
        },
        "chapter_revision": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "author": {
          "type": "string",
          "pattern": "^(?:github|agent|local|system):[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        "status": {
          "type": "string",
          "enum": [
            "open",
            "work_item_created",
            "accepted",
            "resolved",
            "rejected",
            "withdrawn",
            "superseded",
            "orphaned",
            "needs_reanchor"
          ]
        },
        "created_at": {
          "type": "string",
          "pattern": "^\\d{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12]\\d|3[01])T(?:[01]\\d|2[0-3]):[0-5]\\d:(?:[0-5]\\d|60)(?:\\.\\d{1,9})?Z$"
        },
        "scope": {
          "type": "string",
          "const": "range"
        },
        "target": {
          "type": "object",
          "properties": {
            "blockId": {
              "type": "string",
              "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
            },
            "textPosition": {
              "type": "object",
              "properties": {
                "start": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 9007199254740991
                },
                "end": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 9007199254740991
                }
              },
              "required": [
                "start",
                "end"
              ],
              "additionalProperties": false
            },
            "textQuote": {
              "type": "object",
              "properties": {
                "exact": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 8192
                },
                "prefix": {
                  "type": "string",
                  "maxLength": 32
                },
                "suffix": {
                  "type": "string",
                  "maxLength": 32
                }
              },
              "required": [
                "exact"
              ],
              "additionalProperties": false
            }
          },
          "required": [
            "blockId",
            "textPosition",
            "textQuote"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "schema",
        "id",
        "kind",
        "chapter_id",
        "chapter_revision",
        "author",
        "status",
        "created_at",
        "scope",
        "target"
      ],
      "additionalProperties": false
    },
