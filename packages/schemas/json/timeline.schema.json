{
  "$id": "authorbot.timeline/v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema": {
      "type": "string",
      "const": "authorbot.timeline/v1"
    },
    "calendar": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "epoch_label": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^event:[a-z0-9][a-z0-9-]*$"
          },
          "sort_key": {
            "type": "number"
          },
          "display_time": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "participants": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^character:[a-z0-9][a-z0-9-]*$"
            }
          },
          "locations": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^location:[a-z0-9][a-z0-9-]*$"
            }
          },
          "chapter_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
            }
          },
          "facts": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "required": [
          "id",
          "sort_key",
          "display_time",
          "title"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "schema",
    "events"
  ],
  "additionalProperties": false
}
