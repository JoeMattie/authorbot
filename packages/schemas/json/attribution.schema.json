{
  "$id": "authorbot.attribution/v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema": {
      "type": "string",
      "const": "authorbot.attribution/v1"
    },
    "chapter_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "entries": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "revision": {
            "type": "integer",
            "minimum": 1,
            "maximum": 9007199254740991
          },
          "actor": {
            "type": "string",
            "pattern": "^(?:github|agent|local|system):[A-Za-z0-9][A-Za-z0-9._-]*$"
          },
          "work_item_id": {
            "type": "string",
            "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
          },
          "commit": {
            "type": "string",
            "pattern": "^[0-9a-f]{7,64}$"
          }
        },
        "required": [
          "revision",
          "actor"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "schema",
    "chapter_id",
    "entries"
  ],
  "additionalProperties": false
}
