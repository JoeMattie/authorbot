{
  "$id": "authorbot.decision/v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema": {
      "type": "string",
      "const": "authorbot.decision/v1"
    },
    "id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "source_annotation_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "source_reply_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "rule": {
      "type": "string",
      "minLength": 1
    },
    "rule_version": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "metrics": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "number"
      }
    },
    "result": {
      "type": "string",
      "enum": [
        "create_work_item",
        "rejected",
        "support_changed",
        "overridden"
      ]
    },
    "work_item_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "effective_at": {
      "type": "string",
      "pattern": "^\\d{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12]\\d|3[01])T(?:[01]\\d|2[0-3]):[0-5]\\d:(?:[0-5]\\d|60)(?:\\.\\d{1,9})?Z$"
    },
    "override_reason": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "schema",
    "id",
    "source_annotation_id",
    "rule",
    "rule_version",
    "metrics",
    "result",
    "effective_at"
  ],
  "additionalProperties": false
}
