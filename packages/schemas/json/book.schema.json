{
  "$id": "authorbot.book/v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema": {
      "type": "string",
      "const": "authorbot.book/v1"
    },
    "id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "language": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,3}(?:-[A-Za-z0-9]{1,8})*$"
    },
    "license": {
      "type": "string",
      "minLength": 1
    },
    "repository": {
      "type": "object",
      "properties": {
        "default_branch": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "content": {
      "type": "object",
      "properties": {
        "chapters_glob": {
          "type": "string",
          "minLength": 1
        },
        "raw_html": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "planning": {
      "type": "object",
      "properties": {
        "method": {
          "type": "string",
          "minLength": 1
        },
        "outline": {
          "type": "string",
          "minLength": 1
        },
        "timeline": {
          "type": "string",
          "minLength": 1
        },
        "characters_glob": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "publication": {
      "type": "object",
      "properties": {
        "chapter_url": {
          "type": "string",
          "minLength": 1
        },
        "api_url": {
          "type": "string",
          "minLength": 1
        },
        "show_revision": {
          "type": "boolean"
        },
        "show_attribution": {
          "type": "boolean"
        },
        "show_public_annotations": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "governance": {
      "type": "object",
      "properties": {
        "rules": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "version": {
                "type": "integer",
                "minimum": 1,
                "maximum": 9007199254740991
              },
              "trigger": {
                "type": "string",
                "enum": [
                  "vote_changed"
                ]
              },
              "when": {
                "anyOf": [
                  {
                    "type": "object",
                    "properties": {
                      "all": {
                        "minItems": 1,
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "metric": {
                              "type": "string",
                              "pattern": "^[a-z][a-z0-9_]*$"
                            },
                            "operator": {
                              "type": "string",
                              "enum": [
                                "gte",
                                "gt",
                                "lte",
                                "lt",
                                "eq",
                                "neq"
                              ]
                            },
                            "value": {
                              "type": "number"
                            }
                          },
                          "required": [
                            "metric",
                            "operator",
                            "value"
                          ],
                          "additionalProperties": false
                        }
                      }
                    },
                    "required": [
                      "all"
                    ],
                    "additionalProperties": false
                  },
                  {
                    "type": "object",
                    "properties": {
                      "any": {
                        "minItems": 1,
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "metric": {
                              "type": "string",
                              "pattern": "^[a-z][a-z0-9_]*$"
                            },
                            "operator": {
                              "type": "string",
                              "enum": [
                                "gte",
                                "gt",
                                "lte",
                                "lt",
                                "eq",
                                "neq"
                              ]
                            },
                            "value": {
                              "type": "number"
                            }
                          },
                          "required": [
                            "metric",
                            "operator",
                            "value"
                          ],
                          "additionalProperties": false
                        }
                      }
                    },
                    "required": [
                      "any"
                    ],
                    "additionalProperties": false
                  }
                ]
              },
              "action": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "const": "create_work_item"
                  },
                  "work_type": {
                    "type": "string",
                    "enum": [
                      "revise_range",
                      "revise_block",
                      "revise_chapter",
                      "write_chapter",
                      "resolve_conflict",
                      "planning"
                    ]
                  }
                },
                "required": [
                  "type",
                  "work_type"
                ],
                "additionalProperties": false
              }
            },
            "required": [
              "version",
              "when",
              "action"
            ],
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "required": [
    "schema",
    "id",
    "title",
    "slug",
    "language"
  ],
  "additionalProperties": false
}
