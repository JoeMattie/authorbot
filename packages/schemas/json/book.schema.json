{
  "$id": "authorbot.book/v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema": {
      "type": "string",
      "const": "authorbot.book/v1"
    },
    "id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "language": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,3}(?:-[A-Za-z0-9]{1,8})*$"
    },
    "license": {
      "type": "string",
      "minLength": 1
    },
    "repository": {
      "type": "object",
      "properties": {
        "default_branch": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "content": {
      "type": "object",
      "properties": {
        "chapters_glob": {
          "type": "string",
          "minLength": 1
        },
        "raw_html": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "planning": {
      "type": "object",
      "properties": {
        "method": {
          "type": "string",
          "minLength": 1
        },
        "outline": {
          "type": "string",
          "minLength": 1
        },
        "timeline": {
          "type": "string",
          "minLength": 1
        },
        "characters_glob": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "publication": {
      "type": "object",
      "properties": {
        "chapter_url": {
          "type": "string",
          "minLength": 1
        },
        "api_url": {
          "type": "string",
          "minLength": 1
        },
        "show_revision": {
          "type": "boolean"
        },
        "show_attribution": {
          "type": "boolean"
        },
        "show_public_annotations": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  },
  "required": [
    "schema",
    "id",
    "title",
    "slug",
    "language"
  ],
  "additionalProperties": false
}
