{
  "name": "authorbot",
  "version": "0.1.15",
  "description": "Alias for @authorbot/cli — the Git-backed editorial control plane and collaboration protocol for serial books.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "authorbot": "./dist/bin.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "!dist/**/*.map"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JoeMattie/authorbot.git",
    "directory": "packages/authorbot-alias"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"require('fs').chmodSync('dist/bin.js', 0o755)\"",
    "typecheck": "tsc --noEmit",
    "prepack": "node ../../scripts/copy-license.mjs"
  },
  "dependencies": {
    "@authorbot/cli": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
