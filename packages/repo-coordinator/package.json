{
  "name": "@authorbot/repo-coordinator",
  "version": "0.1.0",
  "description": "Outbox processor and Git mirroring for Authorbot: byte-stable annotation/reply artifact rendering, BookRepoWriter with a LocalGitAdapter, and the queued-to-committed git_operations walker (Phase 2 contract section 5)",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@authorbot/database": "workspace:*",
    "@authorbot/domain": "workspace:*",
    "@authorbot/schemas": "workspace:*",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@authorbot/markdown": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
