{
  "name": "@authorbot/repo-coordinator",
  "version": "0.1.34",
  "description": "Outbox processor and Git mirroring for Authorbot: byte-stable annotation/reply artifact rendering, BookRepoWriter with a LocalGitAdapter, and the queued-to-committed git_operations walker (Phase 2 contract section 5)",
  "keywords": [
    "authorbot",
    "outbox",
    "git"
  ],
  "license": "MIT",
  "author": "Joe Mattie",
  "homepage": "https://github.com/JoeMattie/authorbot#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JoeMattie/authorbot.git",
    "directory": "packages/repo-coordinator"
  },
  "bugs": {
    "url": "https://github.com/JoeMattie/authorbot/issues"
  },
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./writer": {
      "types": "./dist/writer.d.ts",
      "default": "./dist/writer.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "CHANGELOG.md",
    "!dist/**/*.map"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "node ../../scripts/copy-license.mjs",
    "test": "vitest run --testTimeout=30000",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@authorbot/database": "workspace:*",
    "@authorbot/domain": "workspace:*",
    "@authorbot/schemas": "workspace:*",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@authorbot/markdown": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
