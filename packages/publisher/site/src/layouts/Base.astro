---
import { site } from "virtual:authorbot-site";
import "../styles/site.css";

const {
  title,
  description,
  noindex = false,
  csp,
  collabStylesHref,
  /**
   * Additional island stylesheets. `/settings/` loads the Phase 7 access-control
   * sheet on top of the collaboration one; every other page passes nothing, so
   * no reader downloads a maintainer-only stylesheet.
   */
  extraStylesHrefs = [],
} = Astro.props;
const base = site.basePath;
// The account strip - sign in, sign out, and the way into Settings and Work.
//
// Shown on every page that already loads the islands bundle, which is the same
// condition as `collabStylesHref`. Deliberately NOT on the story pages: those
// are read-only and stay script-free, and pushing the whole bundle (annotation
// gutters, composer, work queue, settings) onto an outline nobody can edit
// would cost every reader real bytes to render one link.
//
// The index is in the set, which is what matters most: it is where the author
// of a book with no chapters lands, and where there was previously no way to
// sign in at all.
const account = site.collab && collabStylesHref ? site.collab : undefined;
// Astro escapes attribute quotes but keeps `<`/`>` inside attribute values;
// dropping them here guarantees the built output never contains a literal
// `<script` anywhere, even inside a quoted attribute (contract section 6).
const safeDescription =
  typeof description === "string" ? description.replace(/[<>]/g, "") : undefined;
---

<!doctype html>
<html lang={site.book.language}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {csp && <meta http-equiv="Content-Security-Policy" content={csp} />}
    <title>{title}</title>
    {safeDescription && <meta name="description" content={safeDescription} />}
    {noindex && <meta name="robots" content="noindex" />}
    {collabStylesHref && <link rel="stylesheet" href={collabStylesHref} />}
    {extraStylesHrefs.map((href: string) => <link rel="stylesheet" href={href} />)}
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <nav aria-label="Site">
        <a class="book-link" href={base}>{site.book.title}</a>
        <ul class="site-nav">
          <li><a href={`${base}story/`}>Outline</a></li>
          <li><a href={`${base}story/timeline/`}>Timeline</a></li>
          <li><a href={`${base}story/characters/`}>Characters</a></li>
        </ul>
        {account && (
          <authorbot-account
            data-api-base={account.apiBase}
            data-project={account.projectSlug}
            data-base={base}
          ></authorbot-account>
        )}
      </nav>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="site-footer">
      <p>
        {site.book.title}{site.book.license ? ` · ${site.book.license}` : ""}
      </p>
    </footer>
  </body>
</html>
