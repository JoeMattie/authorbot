---
type IconName =
  | "arrow-right"
  | "book-open"
  | "chevron-left"
  | "chevron-right"
  | "flask-conical"
  | "git-branch"
  | "map-pin"
  | "users";

interface Props {
  name: IconName;
  size?: number;
  class?: string;
  label?: string;
}

const {
  name,
  size = 16,
  class: className,
  label,
} = Astro.props;

const paths: Record<IconName, string[]> = {
  "arrow-right": ["M5 12h14", "m13 6 6 6-6 6"],
  "book-open": [
    "M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2Z",
    "M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7Z",
  ],
  "chevron-left": ["m15 18-6-6 6-6"],
  "chevron-right": ["m9 18 6-6-6-6"],
  "flask-conical": [
    "M10 2v7.31",
    "M14 9.3V1.99",
    "M8.5 2h7",
    "M14 9.3 19.52 19a2 2 0 0 1-1.74 3H6.22a2 2 0 0 1-1.74-3L10 9.3",
    "M6.57 16h10.86",
  ],
  "git-branch": ["M6 3v12", "M18 9a3 3 0 0 1-3 3H9", "M18 9V3", "M6 21a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z", "M18 6a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"],
  "map-pin": ["M20 10c0 5-8 12-8 12S4 15 4 10a8 8 0 1 1 16 0Z", "M12 13a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"],
  users: ["M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2", "M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z", "M22 21v-2a4 4 0 0 0-3-3.87", "M16 3.13a4 4 0 0 1 0 7.75"],
};
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden={label ? undefined : "true"}
  aria-label={label}
  role={label ? "img" : undefined}
>
  {paths[name].map((path) => <path d={path} />)}
</svg>
