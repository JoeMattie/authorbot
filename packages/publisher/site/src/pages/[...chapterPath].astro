---
import Base from "../layouts/Base.astro";
import Collab from "../components/Collab.astro";
import Icon from "../components/Icon.astro";
import { SITE_CSP } from "../lib/csp.js";
import { site } from "virtual:authorbot-site";

// One route per included chapter, at the path derived from
// publication.chapter_url (Phase 1 contract section 2). A rest parameter is
// used so the configured pattern controls the directory layout; Astro ranks
// the static index/story routes above this one.
export function getStaticPaths() {
  return site.chapters.map((chapter, index) => ({
    params: { chapterPath: chapter.path },
    props: { index },
  }));
}

const { index } = Astro.props;
const chapter = site.chapters[index];
const prev = index > 0 ? site.chapters[index - 1] : undefined;
const next = index < site.chapters.length - 1 ? site.chapters[index + 1] : undefined;
const showFooter = site.book.showRevision || site.book.showAttribution;

// Collaboration islands (Phase 2b contract §1, §3): only chapter pages of a
// build with an API base emit the CSP meta tag, the island stylesheet, the
// mount element, and the bundled script. Without an API base this page is
// byte-identical with a pre-2b build.
const collab = site.collab;
// Unconditional: this page renders chapter prose through `set:html`, so it
// carries the policy whether or not it also loads the islands (lib/csp.ts).
const csp = SITE_CSP;
const collabStylesHref = collab ? `${site.basePath}_astro/authorbot-collab.css` : undefined;
const chapterCharacters = site.characters.filter((character) =>
  character.chapters.some((entry) => entry.href === chapter.href),
);
const actorLabel = (actor: string) => {
  const [kind, name = actor] = actor.split(":", 2);
  return `${name}${kind === "agent" ? " (agent)" : ""}`;
};
---

<Base
  title={`${chapter.title} · ${site.book.title}`}
  description={chapter.summary}
  noindex={chapter.isDraft}
  csp={csp}
  collabStylesHref={collabStylesHref}
  activeNav="chapters"
>
  <div class="chapter-page">
    <a class="chapter-back" href={site.basePath}>
      <Icon name="chevron-left" size={15} /> All chapters
    </a>
    <div class="chapter-reading-layout ab-reading-layout">
      <div class="chapter-reading-column">
        <article class="chapter">
          {
            chapter.isDraft && (
              <p class="draft-banner" role="status">
                <strong>Draft.</strong> This chapter has status “{chapter.status}” and is
                not part of the published book.
              </p>
            )
          }
          <header class="chapter-header">
            <p class="chapter-kicker">
              <span>Chapter {String(index + 1).padStart(2, "0")}</span>
              <span class={`status-pill status-${chapter.status}`}>{chapter.status}</span>
              {site.book.showRevision && <span>rev {chapter.revision}</span>}
            </p>
            <h1>{chapter.title}</h1>
            {chapter.summary && <p class="chapter-deck">{chapter.summary}</p>}
            {(site.book.showAttribution || chapterCharacters.length > 0) && (
              <div class="chapter-credit-row">
                {site.book.showAttribution && chapter.authors.length > 0 && (
                  <span class="chapter-byline">by {chapter.authors.map(actorLabel).join(" and ")}</span>
                )}
                {chapterCharacters.map((character) => (
                  <a class="character-chip" href={character.href}>{character.name}</a>
                ))}
              </div>
            )}
          </header>
          <div class="prose" set:html={chapter.html} />
          {
            showFooter && (
              <footer class="chapter-footer">
                {site.book.showRevision && <span>Revision {chapter.revision}</span>}
                {site.book.showAttribution && chapter.authors.length > 0 && (
                  <span>By {chapter.authors.map(actorLabel).join(", ")}</span>
                )}
              </footer>
            )
          }
        </article>
      </div>
      {collab && <Collab collab={collab} chapter={chapter} />}
    </div>
  </div>
  <nav class="chapter-nav" aria-label="Chapter navigation">
    <span class="chapter-nav-prev">
      {prev && (
        <a rel="prev" href={prev.href}>
          ← {prev.title}
        </a>
      )}
    </span>
    <span class="chapter-nav-next">
      {next && (
        <a rel="next" href={next.href}>
          {next.title} →
        </a>
      )}
    </span>
  </nav>
  {
    collab && (
      <>
        {/* Phase 6 §3.5: the authoring entry point, and the same composer in
            edit mode. `data-chapter-id` is a build-time attribute, never
            visible UI - that is how editing an existing chapter avoids ever
            showing the author a UUID. Both render nothing until the API says
            the viewer may author, so the reading column is untouched for
            everyone else. */}
        <authorbot-new-chapter
          data-api-base={collab.apiBase}
          data-project={collab.projectSlug}
          data-href={`${site.basePath}write/`}
        />
        <authorbot-chapter-composer
          data-api-base={collab.apiBase}
          data-project={collab.projectSlug}
          data-dev-login={collab.devLogin ? "true" : undefined}
          data-chapter-id={chapter.id}
          data-chapter-title={chapter.title}
          data-chapter-status={chapter.status}
        />
      </>
    )
  }
</Base>
