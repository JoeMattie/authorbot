---
/** Maintainer-only progressive revision queue (Phase 11 slice 4). */
import Base from "../../layouts/Base.astro";
import { SITE_CSP } from "../../lib/csp.js";
import { site } from "virtual:authorbot-site";

export function getStaticPaths() {
  return site.collab ? [{ params: { page: undefined } }] : [];
}

const collab = site.collab;
if (collab === null) {
  throw new Error("revision review page rendered without collaboration config");
}

const csp = SITE_CSP;
const collabStylesHref = `${site.basePath}_astro/authorbot-collab.css`;
const reviewStylesHref = `${site.basePath}_astro/authorbot-revisions.css`;
const src = `${site.basePath}_astro/authorbot-collab.js`;
---

<Base
  title={`Revision review · ${site.book.title}`}
  description="Review proposed manuscript and repository-document revisions."
  noindex={true}
  csp={csp}
  collabStylesHref={collabStylesHref}
  extraStylesHrefs={[reviewStylesHref]}
  activeNav="revisions"
>
  <section class="revision-page">
    <header class="revision-masthead">
      <p class="revision-eyebrow">Editorial review</p>
      <h1>Proposed revisions</h1>
      <p class="revision-intro">
        Compare the complete before and after text, then approve it through the validated Git
        path or reject it without changing the current document.
      </p>
    </header>
    <authorbot-revision-review
      data-api-base={collab.apiBase}
      data-project={collab.projectSlug}
      data-base={site.basePath}
    >
      <p class="revision-fallback">
        Revision proposals load here once JavaScript is enabled. Review requires a maintainer
        credential.
      </p>
    </authorbot-revision-review>
  </section>
  <script is:inline type="module" src={src}></script>
</Base>
