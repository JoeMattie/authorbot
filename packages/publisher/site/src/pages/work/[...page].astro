---
/**
 * The read-only work-queue page (Phase 3 contract §6). Emitted ONLY when the
 * build has an API base: `getStaticPaths` returns the single `/work/` route
 * for a collab build and nothing at all otherwise, so an api-url-less build
 * stays byte-comparable (no page, no script - the script-free regression).
 *
 * Like the chapter island, the bundle is referenced with an `is:inline`
 * script (the same stable `authorbot-collab.js` asset that buildSite emits for
 * collab builds); the mount carries the API config and a trusted chapter map
 * so the island can link each item to its chapter page.
 */
import Base from "../../layouts/Base.astro";
import { site } from "virtual:authorbot-site";

export function getStaticPaths() {
  return site.collab ? [{ params: { page: undefined } }] : [];
}

const collab = site.collab;
if (collab === null) {
  // Unreachable: getStaticPaths emits no route without collab. Guards the type.
  throw new Error("work page rendered without collaboration config");
}

const csp =
  "default-src 'self'; " +
  // Same-origin only (ADR-0019 §1): `'self'` is the whole story.
  "connect-src 'self'; " +
  "img-src 'self' data:";
const collabStylesHref = `${site.basePath}_astro/authorbot-collab.css`;
const src = `${site.basePath}_astro/authorbot-collab.js`;
const chapters = Object.fromEntries(
  site.chapters.map((chapter) => [chapter.id, { title: chapter.title, href: chapter.href }]),
);
---

<Base
  title={`Work queue · ${site.book.title}`}
  description="Ready work items generated from qualifying suggestions."
  noindex={true}
  csp={csp}
  collabStylesHref={collabStylesHref}
>
  <section class="work-page">
    <h1>Work queue</h1>
    <p class="work-intro">
      Ready work items generated from suggestions that met the project's voting rule.
    </p>
    <authorbot-work-queue
      data-api-base={collab.apiBase}
      data-project={collab.projectSlug}
      data-chapters={JSON.stringify(chapters)}
    >
      <p class="work-fallback">The work queue loads here once JavaScript is enabled.</p>
    </authorbot-work-queue>
  </section>
  <script is:inline type="module" src={src}></script>
</Base>
