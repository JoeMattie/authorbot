---
import Base from "../layouts/Base.astro";
import Icon from "../components/Icon.astro";
import { site } from "virtual:authorbot-site";

const compactContributors = (contributors: { label: string }[]): string => {
  const shown = contributors.slice(0, 2).map((credit) => credit.label).join(", ");
  const remaining = contributors.length - 2;
  return remaining > 0 ? `${shown} +${String(remaining)}` : shown;
};

// Phase 6 contract §3.5: the "New chapter" button belongs where an author
// starts - the book's front page - so a book with no chapters at all still
// has a way in. Like every other island it is emitted ONLY for a build with
// an API base: without one this page keeps its byte-comparable, script-free
// output (no CSP meta, no stylesheet link, no script tag).
const collab = site.collab;
const csp = collab
  ? "default-src 'self'; " +
    // Same-origin only (ADR-0019 §1): `'self'` is the whole story.
    "connect-src 'self'; " +
    "img-src 'self' data:"
  : undefined;
const collabStylesHref = collab ? `${site.basePath}_astro/authorbot-collab.css` : undefined;
const src = `${site.basePath}_astro/authorbot-collab.js`;
const publishedDates = site.chapters
  .map((chapter) => chapter.publishedAt)
  .filter((date): date is string => typeof date === "string")
  .sort();
const lastUpdated = publishedDates.at(-1)?.slice(0, 10);
const logline =
  site.outline?.find((node) => node.type === "premise" && node.summary)?.summary ??
  site.chapters.find((chapter) => chapter.summary)?.summary;
---

<Base
  title={site.book.title}
  description={logline}
  csp={csp}
  collabStylesHref={collabStylesHref}
  activeNav="chapters"
>
  <div class="reading-index">
    <header class="book-masthead">
      <p class="page-eyebrow">A serial book, written in the open</p>
      <h1>{site.book.title}</h1>
      {logline && <p class="book-logline">{logline}</p>}
      <p class="book-meta">
        <span>{site.chapters.length} {site.chapters.length === 1 ? "chapter" : "chapters"}</span>
        {site.book.license && <><i aria-hidden="true">·</i><span>{site.book.license}</span></>}
        <i aria-hidden="true">·</i><span>{site.book.language}</span>
        {lastUpdated && <><i aria-hidden="true">·</i><span>updated {lastUpdated}</span></>}
      </p>
    </header>

    {
      collab && (
        <div class="chapter-author-tools" data-collab-only="chapter-tools">
        <authorbot-new-chapter
          data-api-base={collab.apiBase}
          data-project={collab.projectSlug}
          data-href={`${site.basePath}write/`}
        />
        <authorbot-draft-chapters
          data-api-base={collab.apiBase}
          data-project={collab.projectSlug}
        />
        </div>
      )
    }
    {
      site.chapters.length === 0 ? (
        <p class="empty-state">No chapters published yet.</p>
      ) : (
        <ol class="chapter-index">
          {site.chapters.map((chapter, index) => (
            <li data-chapter-activity-id={collab ? chapter.id : undefined}>
              <a href={chapter.href}>
                <span class="chapter-order">{String(index + 1).padStart(2, "0")}</span>
                <span class="chapter-index-copy">
                  <span class="chapter-index-heading">
                    <strong>{chapter.title}</strong>
                    <span class={`status-pill status-${chapter.status}`}>{chapter.status}</span>
                    <span class="chapter-revision">rev {chapter.revision}</span>
                    {collab && <span data-chapter-activity-slot hidden></span>}
                  </span>
                  {chapter.summary && <span class="chapter-summary">{chapter.summary}</span>}
                  {chapter.primaryAuthor && (
                    <span class="chapter-byline">
                      by {chapter.primaryAuthor.label}
                    </span>
                  )}
                  {chapter.contributors.length > 0 && (
                    <span class="chapter-contributors">
                      contributors {compactContributors(chapter.contributors)}
                    </span>
                  )}
                </span>
                <span class="chapter-row-arrow" aria-hidden="true"><Icon name="arrow-right" size={18} /></span>
              </a>
            </li>
          ))}
        </ol>
      )
    }
  </div>
  {
    collab && (
      <authorbot-chapter-activity
        data-api-base={collab.apiBase}
        data-project={collab.projectSlug}
        hidden
      />
    )
  }
  {collab && <script is:inline type="module" src={src} />}
</Base>
