---
import Outline from "../../components/Outline.astro";
import Base from "../../layouts/Base.astro";
import { site } from "virtual:authorbot-site";

const chapterSummaries = site.chapters.filter(
  (chapter) => chapter.status === "published" && chapter.summary,
);
---

<Base title={`Story outline · ${site.book.title}`} activeNav="outline">
  <div class="story-page story-outline-page">
    <header class="story-page-header">
      <p class="story-eyebrow">
        Story outline{site.book.planningMethod ? ` · ${site.book.planningMethod}` : ""}
      </p>
      <h1>How the book is built</h1>
      <p class="story-intro">
        Premise to parts to chapters to scenes. Each scene carries its goal, the conflict
        that resists it, and the outcome it leaves behind.
      </p>
    </header>
    {
      site.outline === null || site.outline.length === 0 ? (
        <p class="story-empty">This book has no outline yet.</p>
      ) : (
        <Outline nodes={site.outline} />
      )
    }
    {
      chapterSummaries.length > 0 && (
        <section class="story-chapter-summaries" aria-labelledby="chapter-summaries-title">
          <header>
            <p class="story-eyebrow">Generated from current chapter metadata</p>
            <h2 id="chapter-summaries-title">Chapter summaries</h2>
          </header>
          <ol>
            {chapterSummaries.map((chapter) => (
              <li>
                <a href={chapter.href}>{chapter.title}</a>
                <p>{chapter.summary}</p>
              </li>
            ))}
          </ol>
        </section>
      )
    }
  </div>
</Base>
