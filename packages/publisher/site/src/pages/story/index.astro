---
import Base from "../../layouts/Base.astro";
import Outline from "../../components/Outline.astro";
import { site } from "virtual:authorbot-site";
---

<Base title={`Story outline · ${site.book.title}`}>
  <h1>Story outline</h1>
  {
    site.outline === null || site.outline.length === 0 ? (
      <p>This book has no outline.</p>
    ) : (
      <Outline nodes={site.outline} />
    )
  }
</Base>
