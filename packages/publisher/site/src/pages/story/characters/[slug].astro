---
import Icon from "../../../components/Icon.astro";
import PlanningEditor from "../../../components/PlanningEditor.astro";
import Base from "../../../layouts/Base.astro";
import { SITE_CSP } from "../../../lib/csp.js";
import { site } from "virtual:authorbot-site";

export function getStaticPaths() {
  return site.characters.map((character, index) => ({
    params: { slug: character.slug },
    props: { index },
  }));
}

const { index } = Astro.props;
const character = site.characters[index];
const characterReadingId = `story-character-document-${character.slug}`;
const planningStyles = site.collab
  ? [`${site.basePath}_astro/authorbot-planning.css`]
  : [];
const monogram = character.name
  .replace(/^Dr\.\s+/u, "")
  .split(/\s+/u)
  .filter(Boolean)
  .slice(0, 2)
  .map((part) => part[0]?.toUpperCase())
  .join("");
---

<Base
  title={`${character.name} · ${site.book.title}`}
  description={character.summary}
  csp={SITE_CSP}
  activeNav="characters"
  extraStylesHrefs={planningStyles}
>
  <article class="story-page character-detail">
    <a class="character-back-link" href={`${site.basePath}story/characters/`}>
      <Icon name="chevron-left" size={16} />
      All characters
    </a>
    <PlanningEditor
      kind="character"
      targetId={character.id}
      path={character.sourcePath}
      label={character.name}
      readingId={characterReadingId}
    />
    <div id={characterReadingId}>
      <header class="character-detail-header">
        <span class="character-avatar character-avatar-large" aria-hidden="true">{monogram}</span>
        <div>
          <h1>{character.name}</h1>
          <p class="character-detail-meta">
            {character.status && (
              <span class={`story-status-pill story-status-${character.status}`}>{character.status}</span>
            )}
            {character.aliases.length > 0 && (
              <span>also known as {character.aliases.join(", ")}</span>
            )}
          </p>
        </div>
      </header>
      {character.summary && <p class="character-detail-summary">{character.summary}</p>}
      <div class="prose character-prose" set:html={character.html} />
    </div>
    {
      character.chapters.length > 0 && (
        <section class="character-appearances">
          <h2>Appears in</h2>
          <ul>
            {character.chapters.map((chapter) => (
              <li><a href={chapter.href}>{chapter.title}</a></li>
            ))}
          </ul>
        </section>
      )
    }
  </article>
</Base>
