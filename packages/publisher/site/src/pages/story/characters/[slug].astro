---
import Base from "../../../layouts/Base.astro";
import { site } from "virtual:authorbot-site";

export function getStaticPaths() {
  return site.characters.map((character, index) => ({
    params: { slug: character.slug },
    props: { index },
  }));
}

const { index } = Astro.props;
const character = site.characters[index];
---

<Base title={`${character.name} · ${site.book.title}`} description={character.summary}>
  <article class="character">
    <header>
      <h1>{character.name}</h1>
      {
        character.aliases.length > 0 && (
          <p class="meta">Also known as {character.aliases.join(", ")}</p>
        )
      }
      {character.status && <p class="meta">Status: {character.status}</p>}
      {character.summary && <p class="summary">{character.summary}</p>}
    </header>
    <div class="prose" set:html={character.html} />
    {
      character.chapters.length > 0 && (
        <section class="appearances">
          <h2>Appears in</h2>
          <ul>
            {character.chapters.map((chapter) => (
              <li>
                <a href={chapter.href}>{chapter.title}</a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </article>
</Base>
