---
/**
 * The maintainer-only book settings page (Phase 6 contract §3.6). Emitted ONLY
 * when the build has an API base: `getStaticPaths` returns the single
 * `/settings/` route for a collab build and nothing at all otherwise, so an
 * api-url-less build emits no page and stays byte-identically script-free.
 *
 * The page itself is public HTML with nothing sensitive in it, the settings
 * document is fetched at runtime by the island, and the API refuses it to
 * anyone who is not a maintainer. `noindex` because a settings screen has no
 * business in search results.
 */
import Base from "../../layouts/Base.astro";
import { SITE_CSP } from "../../lib/csp.js";
import { site } from "virtual:authorbot-site";

export function getStaticPaths() {
  return site.collab ? [{ params: { page: undefined } }] : [];
}

const collab = site.collab;
if (collab === null) {
  // Unreachable: getStaticPaths emits no route without collab. Guards the type.
  throw new Error("settings page rendered without collaboration config");
}

const csp = SITE_CSP;
const collabStylesHref = `${site.basePath}_astro/authorbot-collab.css`;
const src = `${site.basePath}_astro/authorbot-collab.js`;
const settingsSrc = `${site.basePath}_astro/authorbot-settings.js`;
/**
 * Phase 7's access-control surface ships as its own bundle (see `buildIslands`)
 * and is loaded HERE ONLY, a collaborator table, a token list, an audit view
 * and a moderation queue are maintainer-only and have no business in the
 * chapter-page entry every reader downloads.
 */
const accessStylesHref = `${site.basePath}_astro/authorbot-access.css`;
const settingsStylesHref = `${site.basePath}_astro/authorbot-settings.css`;
const accessSrc = `${site.basePath}_astro/authorbot-access.js`;
const brandTitle = site.book.title.toLowerCase().replace(/\.+$/, "");
const safeBookTitle = site.book.title.replace(/[<>]/g, "");
---

<Base
  title={`Book settings · ${site.book.title}`}
  description="Maintainer-only book settings, committed to book.yml like any other change."
  noindex={true}
  csp={csp}
  collabStylesHref={collabStylesHref}
  extraStylesHrefs={[accessStylesHref, settingsStylesHref]}
  settingsConsole={true}
>
  <svg class="settings-icon-sprite" aria-hidden="true">
    <defs>
      <symbol id="ab-icon-flask" viewBox="0 0 24 24"><path d="M9 3h6M10 9 6 17.5A2.4 2.4 0 0 0 8.2 21h7.6a2.4 2.4 0 0 0 2.2-3.5L14 9V3h-4v6Z"/><path d="M8.5 15h7"/></symbol>
      <symbol id="ab-icon-book" viewBox="0 0 24 24"><path d="M2 4.5A2.5 2.5 0 0 1 4.5 2H11v18H4.5A2.5 2.5 0 0 0 2 22V4.5ZM22 4.5A2.5 2.5 0 0 0 19.5 2H13v18h6.5A2.5 2.5 0 0 1 22 22V4.5Z"/></symbol>
      <symbol id="ab-icon-workflow" viewBox="0 0 24 24"><rect x="3" y="3" width="6" height="6" rx="1"/><rect x="15" y="15" width="6" height="6" rx="1"/><path d="M6 9v3a3 3 0 0 0 3 3h6M18 12v3"/></symbol>
      <symbol id="ab-icon-link" viewBox="0 0 24 24"><path d="M10 13a5 5 0 0 0 7.1.1l2-2a5 5 0 0 0-7.1-7.1l-1.1 1.1M14 11a5 5 0 0 0-7.1-.1l-2 2A5 5 0 0 0 12 20l1.1-1.1"/></symbol>
      <symbol id="ab-icon-messages" viewBox="0 0 24 24"><path d="M21 15a4 4 0 0 1-4 4H8l-5 3v-7a4 4 0 0 1-1-2.7V7a4 4 0 0 1 4-4h11a4 4 0 0 1 4 4v8Z"/><path d="M8 9h8M8 13h5"/></symbol>
      <symbol id="ab-icon-users" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8ZM22 21v-2a4 4 0 0 0-3-3.9M16 3.1a4 4 0 0 1 0 7.8"/></symbol>
      <symbol id="ab-icon-key" viewBox="0 0 24 24"><circle cx="8" cy="15" r="5"/><path d="m11.5 11.5 7-7M15 8l3 3M17 6l3 3"/></symbol>
      <symbol id="ab-icon-shield" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="M12 8v4M12 16h.01"/></symbol>
      <symbol id="ab-icon-inbox" viewBox="0 0 24 24"><path d="M4 4h16l2 10v6H2v-6L4 4Z"/><path d="M2 14h5l2 3h6l2-3h5"/></symbol>
      <symbol id="ab-icon-scroll" viewBox="0 0 24 24"><path d="M8 2h10a2 2 0 0 1 2 2v18l-4-3-4 3-4-3-4 3V6a4 4 0 0 1 4-4Z"/><path d="M9 7h6M9 11h6"/></symbol>
    </defs>
  </svg>

  <div class="settings-console" data-settings-console data-active-section="governance">
    <header class="settings-topbar">
      <a class="settings-brand" href={site.basePath} aria-label={`${safeBookTitle} chapters`}>
        <span class="settings-brand-mark"><svg aria-hidden="true"><use href="#ab-icon-flask"></use></svg></span>
        <span class="settings-wordmark">{brandTitle}<span>.</span></span>
      </a>
      <div class="settings-breadcrumb" aria-label="Breadcrumb">
        <a href={site.basePath}>{site.book.title}</a><span aria-hidden="true">›</span><strong>Settings</strong>
      </div>
      <nav class="settings-topnav" aria-label="Book">
        <a href={site.basePath}>Chapters</a>
        <a href={`${site.basePath}story/`}>Outline</a>
        <a href={`${site.basePath}story/timeline/`}>Timeline</a>
        <a href={`${site.basePath}story/characters/`}>Characters</a>
        <a href={`${site.basePath}work/`}>Work</a>
      </nav>
      <span class="settings-topbar-divider" aria-hidden="true"></span>
      <authorbot-account
        data-api-base={collab.apiBase}
        data-project={collab.projectSlug}
        data-base={site.basePath}
      ></authorbot-account>
    </header>

    <div class="settings-console-layout">
      <aside class="settings-sidebar" aria-label="Book settings sections">
        <div class="settings-sidebar-intro">
          <p class="settings-eyebrow">Book settings</p>
          <p>Everything here edits <code>book.yml</code> through a reviewed commit.</p>
        </div>
        <nav class="settings-section-nav" aria-label="Settings">
          <div class="settings-nav-group">
            <p>Book</p>
            <button type="button" data-settings-target="about"><svg aria-hidden="true"><use href="#ab-icon-book"></use></svg><span>About this book</span></button>
            <button type="button" data-settings-target="governance" class="is-active" aria-current="page"><svg aria-hidden="true"><use href="#ab-icon-workflow"></use></svg><span>Governance</span></button>
            <button type="button" data-settings-target="addresses"><svg aria-hidden="true"><use href="#ab-icon-link"></use></svg><span>Addresses</span></button>
          </div>
          <div class="settings-nav-group">
            <p>People &amp; access</p>
            <button type="button" data-settings-target="policy"><svg aria-hidden="true"><use href="#ab-icon-messages"></use></svg><span>Comment policy</span></button>
            <button type="button" data-settings-target="collaborators"><svg aria-hidden="true"><use href="#ab-icon-users"></use></svg><span>Collaborators</span></button>
            <button type="button" data-settings-target="tokens"><svg aria-hidden="true"><use href="#ab-icon-key"></use></svg><span>Agent tokens</span></button>
          </div>
          <div class="settings-nav-group">
            <p>Safety</p>
            <button type="button" data-settings-target="emergency"><svg aria-hidden="true"><use href="#ab-icon-shield"></use></svg><span>Emergency controls</span></button>
            <button type="button" data-settings-target="moderation"><svg aria-hidden="true"><use href="#ab-icon-inbox"></use></svg><span>Review queue</span><span class="settings-nav-count" data-settings-badge="moderation" hidden>0</span></button>
          </div>
          <div class="settings-nav-group">
            <p>Record</p>
            <button type="button" data-settings-target="activity"><svg aria-hidden="true"><use href="#ab-icon-scroll"></use></svg><span>Activity log</span></button>
          </div>
        </nav>
      </aside>

      <div class="settings-panel-scroll">
        <div class="settings-panel">
          <authorbot-settings
            data-api-base={collab.apiBase}
            data-project={collab.projectSlug}
            data-dev-login={collab.devLogin ? "true" : undefined}
          >
            <p class="settings-fallback">
              Book settings load here once JavaScript is enabled. Sign in as a maintainer to edit them.
            </p>
          </authorbot-settings>
          <authorbot-access data-api-base={collab.apiBase} data-project={collab.projectSlug}>
            <p class="settings-fallback">
              Collaborators, agent tokens, the approval queue and this book's activity log load here once JavaScript is enabled. Sign in as a maintainer to manage them.
            </p>
          </authorbot-access>
        </div>
      </div>
    </div>
  </div>
  <script is:inline type="module" src={src}></script>
  <script is:inline type="module" src={settingsSrc}></script>
  <script is:inline type="module" src={accessSrc}></script>
</Base>
