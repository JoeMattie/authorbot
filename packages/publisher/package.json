{
  "name": "@authorbot/publisher",
  "version": "0.1.17",
  "description": "Read-only static-site publisher for Authorbot book repositories: Astro 5 invoked programmatically, sanitized Markdown rendering, story views, and the authorbot.build/v1 manifest (Phase 1 contract sections 1-4)",
  "keywords": [
    "authorbot",
    "astro",
    "static-site",
    "publisher"
  ],
  "license": "MIT",
  "author": "Joe Mattie",
  "homepage": "https://github.com/JoeMattie/authorbot#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JoeMattie/authorbot.git",
    "directory": "packages/publisher"
  },
  "bugs": {
    "url": "https://github.com/JoeMattie/authorbot/issues"
  },
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "site",
    "!site/node_modules",
    "LICENSE",
    "CHANGELOG.md",
    "!dist/**/*.map"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "node ../../scripts/copy-license.mjs",
    "test": "vitest run --testTimeout=30000",
    "test:e2e": "pnpm run build && playwright test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@authorbot/markdown": "workspace:*",
    "@authorbot/schemas": "workspace:*",
    "@types/mdast": "^4.0.0",
    "@types/unist": "^3.0.0",
    "astro": "^5.0.0",
    "vite": "^6.4.0",
    "yaml": "^2.5.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/node": "^22.0.0",
    "happy-dom": "^18.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
