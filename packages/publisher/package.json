{
  "name": "@authorbot/publisher",
  "version": "0.1.0",
  "description": "Read-only static-site publisher for Authorbot book repositories: Astro 5 invoked programmatically, sanitized Markdown rendering, story views, and the authorbot.build/v1 manifest (Phase 1 contract sections 1-4)",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "site"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@authorbot/markdown": "workspace:*",
    "@authorbot/schemas": "workspace:*",
    "@types/mdast": "^4.0.0",
    "@types/unist": "^3.0.0",
    "astro": "^5.0.0",
    "yaml": "^2.5.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
