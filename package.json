{
  "name": "authorbot",
  "private": true,
  "version": "0.1.0",
  "description": "Git-backed editorial control plane and collaboration protocol for serial books",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @authorbot/api build && pnpm --filter @authorbot/publisher test:e2e",
    "typecheck": "pnpm -r typecheck",
    "check:packaging": "node scripts/check-packaging.mjs",
    "check:author-ci": "node scripts/simulate-author-ci.mjs",
    "check:api-tarball": "node scripts/smoke-api-tarball.mjs",
    "validate:example": "pnpm --filter @authorbot/cli start validate examples/book-repo",
    "build:example": "pnpm --filter @authorbot/cli start build examples/book-repo --out _site"
  }
}
