{
  "name": "@authorbot/cli",
  "version": "0.1.39",
  "description": "Authorbot command-line interface: validate Authorbot book repositories against the Phase 0 contract (section 5)",
  "keywords": [
    "authorbot",
    "cli",
    "markdown",
    "book",
    "validate",
    "static-site"
  ],
  "license": "MIT",
  "author": "Joe Mattie",
  "homepage": "https://github.com/JoeMattie/authorbot#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JoeMattie/authorbot.git",
    "directory": "apps/cli"
  },
  "bugs": {
    "url": "https://github.com/JoeMattie/authorbot/issues"
  },
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "bin": {
    "authorbot": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./bin": {
      "types": "./dist/bin.d.ts",
      "default": "./dist/bin.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "CHANGELOG.md",
    "!dist/**/*.map"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"require('fs').chmodSync('dist/bin.js', 0o755)\"",
    "prepack": "node ../../scripts/copy-license.mjs",
    "test": "vitest run --testTimeout=30000",
    "typecheck": "tsc --noEmit",
    "start": "cd ../.. && node apps/cli/dist/bin.js"
  },
  "dependencies": {
    "@authorbot/api": "workspace:*",
    "@authorbot/domain": "workspace:*",
    "@authorbot/markdown": "workspace:*",
    "@authorbot/publisher": "workspace:*",
    "@authorbot/schemas": "workspace:*",
    "yaml": "^2.5.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@authorbot/test-fixtures": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
