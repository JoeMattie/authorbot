{
  "name": "@authorbot/create",
  "version": "0.1.24",
  "description": "Guided setup for an Authorbot book project.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "create-authorbot": "dist/bin.js"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist",
    "LICENSE",
    "CHANGELOG.md",
    "README.md",
    "!dist/**/*.map"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JoeMattie/authorbot.git",
    "directory": "apps/create"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"require('fs').chmodSync('dist/bin.js', 0o755)\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --testTimeout=30000",
    "sync-templates": "node scripts/sync-templates.mjs",
    "prepack": "node ../../scripts/copy-license.mjs"
  },
  "dependencies": {
    "@authorbot/schemas": "workspace:*",
    "@clack/prompts": "^1.7.0",
    "chalk": "^5.6.2",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
