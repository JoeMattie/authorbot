{
  "name": "@authorbot/api",
  "version": "0.1.11",
  "description": "Authorbot Phase 2 API: Hono 4 app for Cloudflare Workers with runtime-agnostic business wiring (identity, annotations, replies, Git-mirroring command flow, projection rebuild, webhook ingest)",
  "keywords": [
    "authorbot",
    "cloudflare-workers",
    "hono",
    "api",
    "collaboration"
  ],
  "license": "MIT",
  "author": "Joe Mattie",
  "homepage": "https://github.com/JoeMattie/authorbot#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JoeMattie/authorbot.git",
    "directory": "apps/api"
  },
  "bugs": {
    "url": "https://github.com/JoeMattie/authorbot/issues"
  },
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./local": {
      "types": "./dist/local.d.ts",
      "default": "./dist/local.js"
    }
  },
  "files": [
    "dist",
    "migrations",
    "LICENSE",
    "!dist/**/*.map"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "node scripts/sync-migrations.mjs && node ../../scripts/copy-license.mjs",
    "test": "vitest run --testTimeout=30000",
    "typecheck": "tsc --noEmit",
    "dev": "wrangler dev",
    "dev:node": "pnpm build && node dist/dev-server.js",
    "migrate:local": "wrangler d1 migrations apply authorbot --local",
    "smoke": "bash scripts/smoke.sh"
  },
  "dependencies": {
    "@authorbot/database": "workspace:*",
    "@authorbot/domain": "workspace:*",
    "@authorbot/git-github": "workspace:*",
    "@authorbot/markdown": "workspace:*",
    "@authorbot/repo-coordinator": "workspace:*",
    "@authorbot/rule-engine": "workspace:*",
    "@authorbot/schemas": "workspace:*",
    "hono": "^4.6.0",
    "yaml": "^2.5.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@authorbot/cli": "workspace:*",
    "@cloudflare/workers-types": "^4.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  }
}
